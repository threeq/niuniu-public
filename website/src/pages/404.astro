---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocaleFromUrl, localePath, t } from '@/lib/i18n';
import Button from '@/components/ui/Button.astro';
const locale = getLocaleFromUrl(Astro.url);
---
<BaseLayout title={`404 · ${t(locale, 'brand.name')}`}>
  <section class="container-page py-32 text-center">
    <h1 class="text-7xl font-extrabold text-[rgb(var(--color-muted))]">404</h1>
    <h2 class="mt-4 text-2xl font-semibold">{t(locale, '404.title')}</h2>
    <p class="mt-2 text-[rgb(var(--color-muted))]">{t(locale, '404.subtitle')}</p>
    <div class="mt-8">
      <Button href={localePath(locale, '/')}>{t(locale, '404.back')}</Button>
    </div>
  </section>
</BaseLayout>
