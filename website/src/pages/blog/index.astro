---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';

const locale: Locale = getLocaleFromUrl(Astro.url);
const posts = (await getCollection('blog-zh', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const [featured, ...rest] = posts;
const fmt = (d: Date) =>
  new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
const iso = (d: Date) => d.toISOString().slice(0, 10);

// SEO keyword sentence — aggregated from every published post, deduped.
const allKeywords = [...new Set(posts.flatMap((p) => p.data.keywords))];
const seoSentence = allKeywords.length
  ? `聚焦 ${allKeywords.join(' · ')} 等主题的实战经验与教程。`
  : t(locale, 'blog.description');
---
<BaseLayout title={`${t(locale, 'blog.title')} · ${t(locale, 'brand.name')}`} description={seoSentence}>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-[rgb(var(--color-border))] gradient-hero">
    <div class="blog-grid-pattern" aria-hidden="true"></div>
    <div class="blog-hero-glow" aria-hidden="true"></div>
    <div class="container-page relative py-16 sm:py-20">
      <div class="max-w-3xl">
        <p class="reveal font-mono text-xs uppercase tracking-[0.25em] text-[rgb(var(--color-primary))]">
          {t(locale, 'brand.name')} · Blog
        </p>
        <h1 class="reveal mt-4 text-4xl sm:text-5xl font-bold tracking-tight" style="animation-delay:60ms">
          {t(locale, 'blog.title')}
        </h1>
        <p class="reveal mt-4 text-lg text-[rgb(var(--color-muted))]" style="animation-delay:120ms">
          {t(locale, 'blog.description')}
        </p>
        <!-- SEO keyword sentence -->
        <p
          class="reveal mt-5 inline-flex items-start gap-2 rounded-lg border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))]/60 px-3.5 py-2 text-sm text-[rgb(var(--color-muted))] backdrop-blur"
          style="animation-delay:180ms"
          data-pagefind-meta="keywords"
        >
          <span class="mt-0.5 font-mono text-[rgb(var(--color-primary))]" aria-hidden="true">#</span>
          <span>{seoSentence}</span>
        </p>
      </div>
    </div>
  </section>

  <div class="container-page py-14">
    {featured && (
      <a
        href={`/blog/${featured.id}`}
        class="reveal group relative block overflow-hidden rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-7 sm:p-9 transition-all duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-primary))]/50 hover:shadow-2xl hover:shadow-[rgb(var(--color-primary))]/10"
      >
        <span
          class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-[rgb(var(--color-primary))] to-[rgb(var(--color-accent))] transition-transform duration-300 group-hover:scale-x-100"
          aria-hidden="true"
        ></span>
        <div class="flex flex-wrap items-center gap-3">
          <span class="inline-flex items-center rounded-full bg-[rgb(var(--color-primary))] px-3 py-1 text-xs font-medium text-[rgb(var(--color-primary-fg))]">
            最新
          </span>
          <span class="inline-flex items-center gap-2 text-sm text-[rgb(var(--color-muted))]">
            <span class="h-1.5 w-1.5 rounded-full bg-[rgb(var(--color-primary))]" aria-hidden="true"></span>
            <time datetime={iso(featured.data.pubDate)}>{fmt(featured.data.pubDate)}</time>
          </span>
        </div>
        <h2 class="mt-5 text-2xl sm:text-3xl font-bold leading-snug transition-colors group-hover:text-[rgb(var(--color-primary))]">
          {featured.data.title}
        </h2>
        <p class="mt-4 max-w-3xl text-[rgb(var(--color-muted))] leading-relaxed line-clamp-3">
          {featured.data.description}
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-2">
          {featured.data.keywords.map((k) => (
            <span class="rounded-full border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] px-2.5 py-1 text-xs text-[rgb(var(--color-muted))] transition-colors group-hover:border-[rgb(var(--color-primary))]/30">
              {k}
            </span>
          ))}
        </div>
        <span class="mt-7 inline-flex items-center gap-1.5 text-sm font-medium text-[rgb(var(--color-primary))]">
          {t(locale, 'blog.read_more')}
          <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
        </span>
      </a>
    )}

    {rest.length > 0 && (
      <>
        <h2 class="reveal mt-14 mb-6 text-sm font-semibold uppercase tracking-widest text-[rgb(var(--color-muted))]">
          {t(locale, 'blog.more')}
        </h2>
        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
          {rest.map((post, i) => (
            <a
              href={`/blog/${post.id}`}
              class="reveal group relative flex flex-col overflow-hidden rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-6 transition-all duration-300 hover:-translate-y-1 hover:border-[rgb(var(--color-primary))]/50 hover:shadow-xl hover:shadow-[rgb(var(--color-primary))]/10"
              style={`animation-delay:${120 + i * 80}ms`}
            >
              <span
                class="absolute inset-x-0 top-0 h-1 origin-left scale-x-0 bg-gradient-to-r from-[rgb(var(--color-primary))] to-[rgb(var(--color-accent))] transition-transform duration-300 group-hover:scale-x-100"
                aria-hidden="true"
              ></span>
              <span class="inline-flex items-center gap-2 text-sm text-[rgb(var(--color-muted))]">
                <span class="h-1.5 w-1.5 rounded-full bg-[rgb(var(--color-primary))]" aria-hidden="true"></span>
                <time datetime={iso(post.data.pubDate)}>{fmt(post.data.pubDate)}</time>
              </span>
              <h3 class="mt-3 text-xl font-semibold leading-snug transition-colors group-hover:text-[rgb(var(--color-primary))]">
                {post.data.title}
              </h3>
              <p class="mt-3 text-sm text-[rgb(var(--color-muted))] leading-relaxed line-clamp-3">
                {post.data.description}
              </p>
              {post.data.keywords.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {post.data.keywords.slice(0, 4).map((k) => (
                    <span class="rounded-full border border-[rgb(var(--color-border))] bg-[rgb(var(--color-bg))] px-2.5 py-1 text-xs text-[rgb(var(--color-muted))] transition-colors group-hover:border-[rgb(var(--color-primary))]/30">
                      {k}
                    </span>
                  ))}
                </div>
              )}
              <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-[rgb(var(--color-primary))]">
                {t(locale, 'blog.read_more')}
                <span class="transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true">→</span>
              </span>
            </a>
          ))}
        </div>
      </>
    )}

    {posts.length === 0 && (
      <p class="text-[rgb(var(--color-muted))]">{t(locale, 'blog.empty')}</p>
    )}
  </div>
</BaseLayout>

<style>
  @keyframes reveal-up {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .reveal { opacity: 0; animation: reveal-up 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards; }

  .blog-hero-glow {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(620px circle at 12% -10%, rgb(var(--color-primary) / 0.16), transparent 60%),
      radial-gradient(520px circle at 92% 10%, rgb(var(--color-accent) / 0.10), transparent 55%);
  }
  .blog-grid-pattern {
    position: absolute; inset: 0; pointer-events: none; opacity: 0.5;
    background-image:
      linear-gradient(rgb(var(--color-border) / 0.6) 1px, transparent 1px),
      linear-gradient(90deg, rgb(var(--color-border) / 0.6) 1px, transparent 1px);
    background-size: 44px 44px;
    -webkit-mask-image: radial-gradient(circle at 30% 0%, black, transparent 72%);
    mask-image: radial-gradient(circle at 30% 0%, black, transparent 72%);
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal { animation: none; opacity: 1; }
  }
</style>
