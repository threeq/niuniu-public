---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';

const locale: Locale = getLocaleFromUrl(Astro.url);
const posts = (await getCollection('blog-zh', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
const fmt = (d: Date) => new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(d);
---
<BaseLayout title={`${t(locale, 'blog.title')} · ${t(locale, 'brand.name')}`} description={t(locale, 'blog.description')}>
  <div class="container-page py-12">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-3xl md:text-4xl font-bold">{t(locale, 'blog.title')}</h1>
      <p class="mt-3 text-lg text-[rgb(var(--color-muted))]">{t(locale, 'blog.description')}</p>
      <div class="mt-10 flex flex-col gap-4">
        {posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-6 transition-shadow hover:shadow-lg"
          >
            <time datetime={post.data.pubDate.toISOString().slice(0, 10)} class="text-sm text-[rgb(var(--color-muted))]">
              {fmt(post.data.pubDate)}
            </time>
            <h2 class="mt-2 text-xl font-semibold group-hover:text-[rgb(var(--color-primary))]">{post.data.title}</h2>
            <p class="mt-2 text-sm text-[rgb(var(--color-muted))] line-clamp-3">{post.data.description}</p>
            {post.data.keywords.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {post.data.keywords.map((k) => (
                  <span class="rounded-full border border-[rgb(var(--color-border))] px-2 py-0.5 text-xs text-[rgb(var(--color-muted))]">{k}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
