---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocaleFromUrl, t } from '@/lib/i18n';
import { softwareApplicationSchema } from '@/lib/structured-data';
import PricingTiers from '@/components/pricing/PricingTiers.astro';
import ComparisonTable from '@/components/pricing/ComparisonTable.astro';
const locale = getLocaleFromUrl(Astro.url);
const siteUrl = Astro.site?.origin ?? 'https://www.niu6ai.com';
---
<BaseLayout
  title={`${t(locale, 'pricing.page_title')} · ${t(locale, 'brand.name')}`}
  structuredData={[softwareApplicationSchema(siteUrl, locale)]}
>
  <section class="container-page pt-12 text-center">
    <h1 class="text-4xl font-extrabold">{t(locale, 'pricing.page_title')}</h1>
    <p class="mt-3 text-[rgb(var(--color-muted))]">{t(locale, 'pricing.page_subtitle')}</p>
  </section>
  <PricingTiers />
  <ComparisonTable />
</BaseLayout>
