---
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);

type Cell = string | boolean;
const rows: { label: { zh: string; en: string }; cells: [Cell, Cell] }[] = [
  { label: { zh: '本地数据', en: 'Local data' }, cells: [true, true] },
  { label: { zh: '多用户协作', en: 'Multi-user' }, cells: [false, true] },
  { label: { zh: '组织 / 团队', en: 'Orgs / teams' }, cells: [false, true] },
  { label: { zh: '数据库后端', en: 'Database backend' }, cells: ['SQLite', 'PostgreSQL'] },
  { label: { zh: '审计日志', en: 'Audit log' }, cells: [false, true] },
  { label: { zh: 'SSO', en: 'SSO' }, cells: [false, true] },
  { label: { zh: '邮件支持', en: 'Email support' }, cells: [false, true] },
  { label: { zh: '专属支持', en: 'Dedicated support' }, cells: [false, true] },
  { label: { zh: '私有化部署', en: 'On-premises' }, cells: [false, true] },
  { label: { zh: 'Workspace 数', en: 'Workspaces' }, cells: ['无限', '无限'] },
  { label: { zh: 'SLA', en: 'SLA' }, cells: ['—', '99.9%'] },
];

function renderCell(c: Cell): string {
  if (c === true) return '✓';
  if (c === false) return '—';
  return c;
}
---
<section class="container-page py-12">
  <h2 class="text-2xl font-bold mb-6">{t(locale, 'pricing.comparison_title')}</h2>
  <div class="overflow-x-auto rounded-xl border border-[rgb(var(--color-border))]">
    <table class="w-full text-sm">
      <thead class="bg-[rgb(var(--color-card))]">
        <tr>
          <th class="text-left p-3 font-semibold"></th>
          <th class="p-3 font-semibold">Personal</th>
          <th class="p-3 font-semibold">Self-Hosted Team</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr class="border-t border-[rgb(var(--color-border))]">
            <td class="p-3 text-left">{r.label[locale]}</td>
            {r.cells.map((c) => (
              <td class="p-3 text-center">
                <span class:list={[c === false ? 'text-[rgb(var(--color-muted))]' : '']}>{renderCell(c)}</span>
              </td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</section>
