---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocaleFromUrl, localePath, t, type Locale } from '@/lib/i18n';
import { breadcrumbSchema, techArticleSchema } from '@/lib/structured-data';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  keywords?: string[];
}
const { slug, title, description, pubDate, keywords = [] } = Astro.props;
const locale: Locale = getLocaleFromUrl(Astro.url);
const siteUrl = Astro.site?.origin ?? 'https://www.niu6ai.com';
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const editPath = `website/src/content/blog-zh/${slug}.md`;
const editUrl = `https://github.com/threeq/niuniu-public/edit/main/${editPath}`;
const dateLabel = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }).format(pubDate);
const isoDate = pubDate.toISOString().slice(0, 10);
const structuredData = [
  techArticleSchema({ siteUrl, url: canonical, title, description, locale }),
  breadcrumbSchema([
    { name: t(locale, 'brand.name'), url: new URL(localePath(locale, '/'), Astro.site).toString() },
    { name: t(locale, 'nav.blog'), url: new URL('/blog', Astro.site).toString() },
    { name: title, url: canonical },
  ]),
];
---
<BaseLayout title={`${title} · ${t(locale, 'brand.name')}`} description={description} structuredData={structuredData}>
  <div class="container-page py-10">
    <article class="mx-auto max-w-3xl">
      <a href="/blog" class="text-sm text-[rgb(var(--color-muted))] hover:text-[rgb(var(--color-primary))]">← {t(locale, 'blog.back')}</a>
      <h1 class="mt-4 text-3xl md:text-4xl font-bold">{title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-[rgb(var(--color-muted))]">
        <time datetime={isoDate}>{dateLabel}</time>
        {keywords.length > 0 && (
          <span class="flex flex-wrap gap-2">
            {keywords.map((k) => (
              <span class="rounded-full border border-[rgb(var(--color-border))] px-2 py-0.5 text-xs">{k}</span>
            ))}
          </span>
        )}
      </div>
      <p class="mt-4 text-lg text-[rgb(var(--color-muted))]">{description}</p>
      <div class="prose prose-zinc dark:prose-invert max-w-none mt-8">
        <slot />
      </div>
      <p class="mt-10 text-sm text-[rgb(var(--color-muted))]">
        <a href={editUrl} rel="noopener noreferrer" class="hover:text-[rgb(var(--color-fg))]">{t(locale, 'docs.edit_on_github')} →</a>
      </p>
    </article>
  </div>
</BaseLayout>
