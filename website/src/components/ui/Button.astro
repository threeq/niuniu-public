---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  rel?: string;
  target?: string;
}
const { href, variant = 'primary', size = 'md', class: className = '', rel, target } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 rounded-lg font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2';
const variants = {
  primary: 'bg-[rgb(var(--color-primary))] text-[rgb(var(--color-primary-fg))] hover:opacity-90',
  secondary: 'bg-[rgb(var(--color-card))] text-[rgb(var(--color-fg))] border border-[rgb(var(--color-border))] hover:bg-[rgb(var(--color-bg))]',
  ghost: 'text-[rgb(var(--color-fg))] hover:bg-[rgb(var(--color-card))]',
};
const sizes = { sm: 'h-8 px-3 text-sm', md: 'h-10 px-4', lg: 'h-12 px-6 text-lg' };
const cls = `${base} ${variants[variant]} ${sizes[size]} ${className}`;
const isExternal = !!href && /^(https?:|mailto:)/.test(href);
const computedRel = rel ?? (isExternal ? 'noopener noreferrer' : undefined);
const Tag = href ? 'a' : 'button';
---
<Tag class={cls} href={href} rel={computedRel} target={target}>
  <slot />
</Tag>
