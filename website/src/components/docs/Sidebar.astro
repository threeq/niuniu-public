---
import { buildNav, getDocsForLocale } from '@/lib/docs-nav';
import { getLocaleFromUrl, localePath, t, type Locale } from '@/lib/i18n';

interface Props { currentSlug: string; }
const { currentSlug } = Astro.props;
const locale: Locale = getLocaleFromUrl(Astro.url);
const docs = await getDocsForLocale(locale);
const groups = buildNav(docs);
---
<aside class="w-64 shrink-0 border-r border-[rgb(var(--color-border))] py-8 pr-6 hidden md:block">
  <nav class="space-y-6 text-sm">
    {groups.map((g) => (
      <div>
        <h3 class="font-semibold mb-2">{t(locale, `groups.${g.group}`)}</h3>
        <ul class="space-y-1">
          {g.items.map((it) => {
            const active = it.slug === currentSlug;
            return (
              <li>
                <a
                  href={localePath(locale, `/docs/${it.slug}`)}
                  class:list={[
                    'block rounded px-2 py-1',
                    active
                      ? 'bg-[rgb(var(--color-primary))]/10 text-[rgb(var(--color-primary))] font-medium'
                      : 'text-[rgb(var(--color-muted))] hover:text-[rgb(var(--color-fg))]'
                  ]}
                >{it.title}</a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </nav>
</aside>
