---
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';
import zh from '@/i18n/zh.json';
import en from '@/i18n/en.json';
const locale: Locale = getLocaleFromUrl(Astro.url);
const dict = locale === 'zh' ? zh : en;
const steps = dict.goal_loop.steps as { n: string; title: string; desc: string }[];
---
<section class="container-page py-20">
  <div class="text-center max-w-2xl mx-auto">
    <p class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-primary))]">
      {t(locale, 'goal_loop.section_eyebrow')}
    </p>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold">
      {t(locale, 'goal_loop.section_title')}
    </h2>
    <p class="mt-4 text-[rgb(var(--color-muted))]">
      {t(locale, 'goal_loop.section_subtitle')}
    </p>
  </div>

  <ol class="mt-14 grid gap-5 md:grid-cols-5">
    {steps.map((step, i) => (
      <li class="relative rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-5">
        <div class="flex items-center gap-2">
          <span class="inline-flex h-7 w-7 items-center justify-center rounded-full bg-[rgb(var(--color-primary))] text-xs font-semibold text-white">
            {step.n}
          </span>
          <h3 class="font-semibold">{step.title}</h3>
        </div>
        <p class="mt-3 text-sm text-[rgb(var(--color-muted))] leading-relaxed">
          {step.desc}
        </p>
        {i < steps.length - 1 && (
          <span class="hidden md:block absolute -right-3 top-1/2 -translate-y-1/2 text-[rgb(var(--color-muted))] select-none" aria-hidden="true">→</span>
        )}
      </li>
    ))}
  </ol>
</section>
