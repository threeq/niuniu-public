---
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';
import zh from '@/i18n/zh.json';
import en from '@/i18n/en.json';
const locale: Locale = getLocaleFromUrl(Astro.url);
const dict = locale === 'zh' ? zh : en;
const stats = dict.social_proof.stats as { value: string; label: string }[];
// NOTE: Placeholder testimonials — swap in real, attributable user quotes before
// treating these as verified social proof. Attributions are role-based on purpose.
const testimonials = dict.social_proof.testimonials as { quote: string; author: string; role: string }[];

const repo = 'threeq/niuniu-public';
const badges = [
  { src: `https://img.shields.io/github/stars/${repo}?style=flat&logo=github&color=f5a623`, href: `https://github.com/${repo}/stargazers` },
  { src: `https://img.shields.io/github/downloads/${repo}/total?logo=github&label=downloads`, href: `https://github.com/${repo}/releases` },
  { src: `https://img.shields.io/github/v/release/${repo}?display_name=tag&logo=github`, href: `https://github.com/${repo}/releases/latest` },
];
---
<section class="container-page py-20">
  <div class="text-center max-w-2xl mx-auto">
    <p class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-primary))]">
      {t(locale, 'social_proof.section_eyebrow')}
    </p>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold">{t(locale, 'social_proof.section_title')}</h2>
    <p class="mt-4 text-[rgb(var(--color-muted))]">{t(locale, 'social_proof.section_subtitle')}</p>
  </div>

  <div class="mt-8 flex flex-wrap justify-center items-center gap-3">
    {badges.map((b) => (
      <a href={b.href} target="_blank" rel="noopener noreferrer" class="inline-flex">
        <img src={b.src} alt="GitHub" height="20" loading="lazy" decoding="async" />
      </a>
    ))}
  </div>

  <dl class="mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
    {stats.map((s) => (
      <div class="rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-6 text-center">
        <dt class="text-3xl font-extrabold bg-gradient-to-br from-blue-600 to-pink-500 bg-clip-text text-transparent">{s.value}</dt>
        <dd class="mt-2 text-sm text-[rgb(var(--color-muted))]">{s.label}</dd>
      </div>
    ))}
  </dl>

  <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-6">
    {testimonials.map((item) => (
      <figure class="flex flex-col rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-6">
        <blockquote class="flex-1 text-sm leading-relaxed">
          <span class="text-2xl leading-none text-[rgb(var(--color-primary))]" aria-hidden="true">“</span>
          {item.quote}
        </blockquote>
        <figcaption class="mt-5 flex items-center gap-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-gradient-to-br from-blue-600 to-pink-500 text-sm font-semibold text-white" aria-hidden="true">
            {item.author.slice(0, 1)}
          </span>
          <span>
            <span class="block text-sm font-semibold">{item.author}</span>
            <span class="block text-xs text-[rgb(var(--color-muted))]">{item.role}</span>
          </span>
        </figcaption>
      </figure>
    ))}
  </div>
</section>
