---
import { getLocaleFromUrl, localePath, t, type Locale } from '@/lib/i18n';
import Button from '@/components/ui/Button.astro';
const locale: Locale = getLocaleFromUrl(Astro.url);
---
<section class="gradient-hero">
  <div class="container-page py-20 md:py-28 grid md:grid-cols-2 gap-12 items-center">
    <div>
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight bg-gradient-to-br from-blue-600 to-pink-500 bg-clip-text text-transparent leading-[1.1]">
        {t(locale, 'hero.headline')}
      </h1>
      <p class="mt-5 text-lg text-[rgb(var(--color-muted))] max-w-xl">
        {t(locale, 'hero.subhead')}
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={localePath(locale, '/changelog')} size="lg">
          ↓ {t(locale, 'hero.cta_primary')}
        </Button>
        <Button href={localePath(locale, '/docs/install/self-hosted')} variant="secondary" size="lg">
          {t(locale, 'hero.cta_secondary')}
        </Button>
      </div>
    </div>
    <div class="relative">
      <div class="aspect-video overflow-hidden rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] shadow-2xl shadow-blue-500/10">
        <img
          src="/images/dashboard-preview.png"
          alt={t(locale, 'hero.dashboard_alt')}
          width="1366"
          height="768"
          loading="eager"
          decoding="async"
          class="h-full w-full object-cover object-left-top"
        />
      </div>
    </div>
  </div>
</section>
