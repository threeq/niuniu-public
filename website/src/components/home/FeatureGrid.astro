---
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';
import zh from '@/i18n/zh.json';
import en from '@/i18n/en.json';
const locale: Locale = getLocaleFromUrl(Astro.url);
const dict = locale === 'zh' ? zh : en;
const items = dict.features.items as { title: string; desc: string }[];
const icons = ['🎯', '🗂', '🔀', '📋', '🎬', '📊', '🧠', '💬', '⏰'];
---
<section class="container-page py-20">
  <div class="text-center max-w-2xl mx-auto">
    <h2 class="text-3xl font-bold">{t(locale, 'features.section_title')}</h2>
  </div>
  <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {items.map((item, i) => (
      <div class="rounded-xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-6 hover:shadow-lg transition-shadow">
        <div class="text-2xl">{icons[i] ?? '✨'}</div>
        <h3 class="mt-3 font-semibold">{item.title}</h3>
        <p class="mt-2 text-sm text-[rgb(var(--color-muted))]">{item.desc}</p>
      </div>
    ))}
  </div>
</section>
