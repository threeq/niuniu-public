---
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
---
<section class="container-page py-12">
  <div class="rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-2 shadow-2xl shadow-blue-500/10">
    <div class="rounded-lg overflow-hidden bg-[rgb(var(--color-bg))] aspect-[16/9]">
      <img
        src="/images/console-screenshot.png"
        alt={t(locale, 'screenshot.alt')}
        width="1500"
        height="900"
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover object-top"
      />
    </div>
  </div>
  <p class="mt-4 text-center text-sm text-[rgb(var(--color-muted))]">{t(locale, 'screenshot.caption')}</p>
</section>
