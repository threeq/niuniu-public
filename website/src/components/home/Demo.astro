---
import { getLocaleFromUrl, t, type Locale } from '@/lib/i18n';
const locale: Locale = getLocaleFromUrl(Astro.url);
---
<section class="container-page py-20">
  <div class="text-center max-w-2xl mx-auto">
    <p class="text-xs font-semibold uppercase tracking-wider text-[rgb(var(--color-primary))]">
      {t(locale, 'demo.section_eyebrow')}
    </p>
    <h2 class="mt-3 text-3xl md:text-4xl font-bold">{t(locale, 'demo.section_title')}</h2>
    <p class="mt-4 text-[rgb(var(--color-muted))]">{t(locale, 'demo.section_subtitle')}</p>
  </div>

  <figure class="mt-12 mx-auto max-w-4xl">
    <div class="rounded-2xl border border-[rgb(var(--color-border))] bg-[rgb(var(--color-card))] p-2 shadow-2xl shadow-blue-500/10">
      <div class="rounded-lg overflow-hidden bg-[rgb(var(--color-bg))] aspect-video">
        <img
          src="/images/demo.gif"
          alt={t(locale, 'demo.alt')}
          width="960"
          height="540"
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover"
        />
      </div>
    </div>
    <figcaption class="mt-4 text-center text-sm text-[rgb(var(--color-muted))]">
      {t(locale, 'demo.caption')}
      <span class="block mt-1 text-xs opacity-70">{t(locale, 'demo.note')}</span>
    </figcaption>
  </figure>
</section>
