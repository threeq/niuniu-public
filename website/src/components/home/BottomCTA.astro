---
import { getLocaleFromUrl, localePath, t, type Locale } from '@/lib/i18n';
import Button from '@/components/ui/Button.astro';
const locale: Locale = getLocaleFromUrl(Astro.url);
---
<section class="container-page py-20">
  <div class="rounded-2xl bg-gradient-to-br from-blue-600 to-pink-500 p-12 text-white text-center">
    <h2 class="text-3xl md:text-4xl font-bold">{t(locale, 'bottom_cta.headline')}</h2>
    <p class="mt-3 text-white/80">{t(locale, 'bottom_cta.subhead')}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href={localePath(locale, '/changelog')} class="!bg-white !text-[rgb(var(--color-primary))] hover:!opacity-90">
        ↓ {t(locale, 'bottom_cta.primary')}
      </Button>
      <Button href={localePath(locale, '/docs/intro')} variant="ghost" class="!text-white border border-white/30 hover:!bg-white/10">
        {t(locale, 'bottom_cta.secondary')}
      </Button>
    </div>
  </div>
</section>
