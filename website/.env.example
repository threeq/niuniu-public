# Third-party analytics (dual deployment). Copy to `.env` and fill in.
# Leave a value blank to disable that provider; both blank = no analytics.

# Baidu Tongji (mainland-China coverage) — the hash in https://hm.baidu.com/hm.js?<id>
PUBLIC_BAIDU_ANALYTICS_ID=

# Cloudflare Web Analytics (global, cookieless) — beacon token
PUBLIC_CF_BEACON_TOKEN=
